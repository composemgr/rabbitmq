# RabbitMQ — environment variable reference
# Copy relevant lines to a .env file alongside docker-compose.yaml

# Timezone
TZ=America/New_York

# Admin credentials
DB_ADMIN_NAME=admin
DB_ADMIN_PASS=changeme_admin_password

# Node configuration
NODE_NAME=rabbit@rabbitmq
NODE_IP_ADDRESS=0.0.0.0
RABBITMQ_DEFAULT_VHOST=/

# Enabled plugins (comma-separated)
RABBITMQ_ENABLE_PLUGINS=rabbitmq_management,rabbitmq_mqtt
